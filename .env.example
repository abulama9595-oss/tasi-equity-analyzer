# TASI Equity Analyzer — environment variable NAMES only (NO secrets here).
# Copy this file to `.env` and fill in values you have. The app runs yfinance-only
# (no key needed) if SAHMK_API_KEY is absent — Saudi-Exchange-sourced fields are
# then marked unavailable. config.yaml references these names, never the values.

# Saudi Exchange market data via SAHMK (Tadawul-licensed). Free tier ~100 req/day,
# ~15-min delayed quotes. Get a key at https://app.sahmk.sa
SAHMK_API_KEY=

# Optional — news/disclosures alternative (Argaam-sourced, free tier).
MARKETAUX_API_KEY=

# Optional — paid fundamentals (Twelve Data, exchange code XSAU).
TWELVEDATA_API_KEY=
